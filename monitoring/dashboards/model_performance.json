{
    "title": "FraudOps Model Performance",
    "tags": [
        "fraudops",
        "model"
    ],
    "timezone": "browser",
    "panels": [
        {
            "title": "Fraud Recall",
            "type": "stat",
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 6,
                "h": 6
            },
            "targets": [
                {
                    "expr": "fraudops_model_recall",
                    "legendFormat": "Recall"
                }
            ],
            "options": {
                "thresholds": {
                    "steps": [
                        {
                            "color": "red",
                            "value": 0
                        },
                        {
                            "color": "yellow",
                            "value": 0.7
                        },
                        {
                            "color": "green",
                            "value": 0.85
                        }
                    ]
                }
            }
        },
        {
            "title": "AUC-ROC",
            "type": "stat",
            "gridPos": {
                "x": 6,
                "y": 0,
                "w": 6,
                "h": 6
            },
            "targets": [
                {
                    "expr": "fraudops_model_auc_roc",
                    "legendFormat": "AUC-ROC"
                }
            ]
        },
        {
            "title": "F1 Score",
            "type": "stat",
            "gridPos": {
                "x": 12,
                "y": 0,
                "w": 6,
                "h": 6
            },
            "targets": [
                {
                    "expr": "fraudops_model_f1",
                    "legendFormat": "F1"
                }
            ]
        },
        {
            "title": "False Positive Rate",
            "type": "stat",
            "gridPos": {
                "x": 18,
                "y": 0,
                "w": 6,
                "h": 6
            },
            "targets": [
                {
                    "expr": "fraudops_model_false_positive_rate",
                    "legendFormat": "FPR"
                }
            ]
        },
        {
            "title": "Recall Over Time",
            "type": "timeseries",
            "gridPos": {
                "x": 0,
                "y": 6,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "fraudops_model_recall",
                    "legendFormat": "Recall"
                }
            ]
        },
        {
            "title": "Fraud vs Legit Predictions",
            "type": "timeseries",
            "gridPos": {
                "x": 12,
                "y": 6,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "rate(fraudops_fraud_predictions_total[5m])",
                    "legendFormat": "Fraud predictions/sec"
                },
                {
                    "expr": "rate(fraudops_legit_predictions_total[5m])",
                    "legendFormat": "Legit predictions/sec"
                }
            ]
        },
        {
            "title": "Prediction Confidence Distribution",
            "type": "timeseries",
            "gridPos": {
                "x": 0,
                "y": 14,
                "w": 24,
                "h": 8
            },
            "targets": [
                {
                    "expr": "rate(fraudops_prediction_confidence_bucket[5m])",
                    "legendFormat": "confidence {{le}}"
                }
            ]
        }
    ],
    "schemaVersion": 36,
    "version": 1
}